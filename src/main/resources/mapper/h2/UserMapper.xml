<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- Mapperとxmlのマッピング -->
<mapper namespace="com.example.demo.user.repository.UserMapper">

  <!-- マッピング定義（ユーザー） -->
  <resultMap type="com.example.demo.user.domain.model.MUser" id="user">
    <id column="user_id" property="userId" />
    <result column="password" property="password" />
    <result column="user_name" property="userName" />
    <result column="birthday" property="birthday" />
    <result column="age" property="age" />
    <result column="gender" property="gender" />
    <result column="department_id" property="departmentId" />
    <result column="role" property="role" />
  </resultMap>

  <!-- ユーザー1件登録 -->
  <insert id="insertOne">
      INSERT INTO m_user(
          user_id
        , password
        , user_name
        , birthday
        , age
        , gender
        , department_id
        , role
      )
      VALUES (
          #{userId}
        , #{password}
        , #{userName}
        , #{birthday}
        , #{age}
        , #{gender}
        , #{departmentId}
        , #{role}
      )
  </insert>
  
  <!-- ユーザー件数取得 -->
  <select id="count" resultType="int">
  		SELECT
  			count(*)
  		FROM
  			m_user
  <where>
  	<if test="userId != null">
  		user_id LIKE '%' || #{userId} || '%'
  	</if>
  	<if test="userName != null">
  		AND user_name like '%' || #{userName} || '%'
  	</if>
  </where>
  </select>
  
  <!-- ユーザー複数件取得 -->
  <select id="findMany" resultType="MUser">
      SELECT
          *
      FROM
          m_user
  <where>
  	<if test="user.userId != null">
  		user_id like '%' || #{user.userId} || '%'
  	</if>
  	<if test="user.userName != null">
  		AND user_name like '%' || #{user.userName} || '%'
  	</if>
  </where>
  <if test="pageable != null and pageable.pageSize>0">
  		LIMIT #{pageable.pageSize}
  		OFFSET #{pageable.offset}
  </if>
  </select>
  
  <!-- ユーザー1件検索 -->
  <select id="findOne" resultMap="user">
      SELECT
          *
      FROM
          m_user
      WHERE
          user_id = #{userId}
  </select>
  
  <!-- ユーザー1件更新 -->
  <update id="updateOne">
  		UPDATE
  			m_user
  		SET
  			password = #{password}
  			,user_name = #{userName}
  		WHERE
  			user_id = #{userId}
  </update>
  
  <!-- ユーザー1件削除 -->
  <delete id="deleteOne">
  		DELETE FROM
  			m_user
  		WHERE
  			user_id = #{userId}
  </delete>
</mapper>
